{
  "manifest_version": 3,
  "name": "HubHop",
  "version": "0.1.0",
  "description": "Jump to any GitHub repo from the address bar. Type 'hh <repo>' and go.",
  "permissions": ["omnibox", "storage", "alarms", "tabs"],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "hh"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
